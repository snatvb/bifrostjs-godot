[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true


[libraries]
linux.debug.x86_64 =     "res://../target/debug/libbifrost_js.so"
linux.release.x86_64 =   "res://../target/release/libbifrost_js.so"
windows.debug.x86_64 =   "res://../target/debug/bifrost_js.dll"
windows.release.x86_64 = "res://../target/release/bifrost_js.dll"
macos.debug =            "res://../target/debug/libbifrost_js.dylib"
macos.release =          "res://../target/release/libbifrost_js.dylib"
macos.debug.arm64 =      "res://../target/debug/libbifrost_js.dylib"
macos.release.arm64 =    "res://../target/release/libbifrost_js.dylib"

